{
  "id": "/",
  "name": "Morphic",
  "short_name": "Morphic",
  "description": "An AI-powered answer engine with a native-feeling search and chat experience.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "browser"],
  "background_color": "#000000",
  "theme_color": "#000000",
