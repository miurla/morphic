  "categories": ["productivity", "utilities", "news"],
  "icons": [
    {
      "src": "/icons/icon-any.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-maskable.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "New Search",
      "short_name": "Search",
      "description": "Start a new Morphic search",
      "url": "/"
    }
  ]
}
